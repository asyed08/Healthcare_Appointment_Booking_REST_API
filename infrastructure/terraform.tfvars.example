# Copy this file to terraform.tfvars and fill in real values.
# Never commit terraform.tfvars — it contains secrets.

app_service_sku = "F1"

# Neon Tech Postgres — use the JDBC format (not the libpq format Neon shows you)
spring_datasource_url      = "jdbc:postgresql://ep-your-endpoint.neon.tech/neondb?sslmode=require"
spring_datasource_username = "neondb_owner"
spring_datasource_password = "your-neon-password"

# Confluent Cloud Kafka
kafka_bootstrap_servers = "pkc-xxxxx.eastus.azure.confluent.cloud:9092"
kafka_sasl_jaas_config  = "org.apache.kafka.common.security.plain.PlainLoginModule required username=\"YOUR_API_KEY\" password=\"YOUR_API_SECRET\";"

# JWT — must be a Base64-encoded string of at least 32 characters
jwt_secret_key = "404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970"

# Gmail sender account
mail_username = "your-email@gmail.com"
mail_password = "your-gmail-app-password"

# GitHub Container Registry — create a PAT at github.com/settings/tokens with read:packages scope
ghcr_username = "your-github-username"
ghcr_token    = "ghp_your_personal_access_token"
ghcr_image    = "ghcr.io/your-github-username/healthcare_appointment_booking_rest_api"
